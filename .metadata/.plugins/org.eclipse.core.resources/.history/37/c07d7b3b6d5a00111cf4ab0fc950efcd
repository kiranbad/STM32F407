#include "stm32f407xx.h"

/************* DELAY *************/
void delay(void)
{
    for(uint32_t i = 0; i < 50000; i++);
}


void PWM_GPIO_Init(void)
{
    GPIO_Handle_t pwm;

    GPIO_PeriClockControl(GPIOD, ENABLE);

    pwm.pGPIOx = GPIOD;
    pwm.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_12;
    pwm.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_ALTFN;
    pwm.GPIO_PinConfig.GPIO_PinAltFunMode = 2;
    pwm.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    pwm.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    pwm.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;

    GPIO_Init(&pwm);
}
/************* TIMER PWM INIT *************/
void TIM4_PWM_Init(void)
{
    // Enable TIM3 clock
	TIM4_PCLK_EN();

    // Prescaler → 16 MHz / 16 = 1 MHz
    TIM4->PSC = 16 - 1;

    // Auto reload → 1000 counts → 1 kHz PWM
    TIM4->ARR = 1000 - 1;

    // Start with 0% duty
    TIM4->CCR1 = 0;

    // PWM Mode 1 (OC1M = 110)
    TIM4->CCMR1 &= ~(7 << 4);
    TIM4->CCMR1 |= (6 << 4);
    TIM4->CCMR1 |= (1 << 3);

    // Enable preload
    TIM4->CCMR1 |= (1 << 3);

    // Enable channel output
    TIM4->CCER |= TIM_CCER_CC1E;
    // Enable auto-reload preload
    TIM4->CR1 |= (1 << 7);

    // Generate update event
    TIM4->EGR |= (1 << 0);

    // Start timer
    TIM4->CR1 |= (1 << 0);
}

/************* SET DUTY *************/
void PWM_SetDuty(uint16_t duty)
{
    if(duty > 1000) duty = 1000;
    TIM4->CCR1 = duty;
}

/************* MAIN *************/
int main(void)
{
    GPIO_Handle_t led;

    GPIO_PeriClockControl(GPIOD, ENABLE);

    led.pGPIOx = GPIOD;
    led.GPIO_PinConfig.GPIO_PinNumber = GPIO_PIN_NO_12;
    led.GPIO_PinConfig.GPIO_PinMode = GPIO_MODE_OUT;
    led.GPIO_PinConfig.GPIO_PinOPType = GPIO_OP_TYPE_PP;
    led.GPIO_PinConfig.GPIO_PinPuPdControl = GPIO_NO_PUPD;
    led.GPIO_PinConfig.GPIO_PinSpeed = GPIO_SPEED_FAST;

    GPIO_Init(&led);

    while(1)
    {
        GPIO_ToggleOutputPin(GPIOD, GPIO_PIN_NO_12);

        for(uint32_t i=0;i<500000;i++);
    }
}
