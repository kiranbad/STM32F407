/**
  * @brief  Microsecond delay function using TIM3
  */
void delay_us(uint16_t us)
{
    uint32_t start = __HAL_TIM_GET_COUNTER(&htim3);
    while((uint32_t)(__HAL_TIM_GET_COUNTER(&htim3) - start) < us);
}

/**
  * @brief  Generates the required 10us trigger pulse for HC-SR04
  */
void HCSR04_Trigger(void)
{
    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_RESET);
    delay_us(2);

    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_SET);
    delay_us(10);

    HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_RESET);
}

/**
  * @brief  Triggers the sensor and waits for the echo response within an RTOS safe window
  */
float HCSR04_ReadDistance(void)
{
    // Reset flags before initiating a reading pulse
    Is_First_Captured = 0;
    __HAL_TIM_SET_CAPTUREPOLARITY(&htim2, TIM_CHANNEL_1, TIM_INPUTCHANNELPOLARITY_RISING);

    // Pulse the trigger line
    HCSR04_Trigger();

    // Loop cleanly yielding to other tasks while waiting for ISR processing
    // Echo pulse width spans up to ~38ms max
    uint32_t startTime = xTaskGetTickCount();
    while(Is_First_Captured != 0 || Distance == 0)
    {
        // 45ms timeout protection guard if the sensor is unplugged or misses an edge
        if((xTaskGetTickCount() - startTime) > pdMS_TO_TICKS(45))
        {
            return -1.0f;
        }
        vTaskDelay(pdMS_TO_TICKS(1));
    }

    return Distance;
}

/**
  * @brief  Input Capture Interrupt Callback for TIM2 Channel 1
  */
void HAL_TIM_IC_CaptureCallback(TIM_HandleTypeDef *htim)
{
    if(htim->Channel == HAL_TIM_ACTIVE_CHANNEL_1)
    {
        if(Is_First_Captured == 0)
        {
            // Read timestamp of the rising edge
            IC_Val1 = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);
            Is_First_Captured = 1;

            // Switch to watch for the falling edge
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1, TIM_INPUTCHANNELPOLARITY_FALLING);
        }
        else
        {
            // Read timestamp of the falling edge
            IC_Val2 = HAL_TIM_ReadCapturedValue(htim, TIM_CHANNEL_1);

            // Calculate exact elapsed delta (handles 32-bit counter overflow conditions)
            if(IC_Val2 > IC_Val1)
            {
                Difference = IC_Val2 - IC_Val1;
            }
            else
            {
                Difference = (0xFFFFFFFF - IC_Val1) + IC_Val2;
            }

            // Fixed Prescaler Math: 42MHz / 42 = 1MHz Timer Clock -> 1 tick = 1 microsecond.
            // Distance (cm) = (Time in us * Speed of sound 0.0343 cm/us) / 2
            Distance = (float)Difference * 0.01715f;
            Is_First_Captured = 0;

            // Toggle back to wait for the next rising pulse sequence
            __HAL_TIM_SET_CAPTUREPOLARITY(htim, TIM_CHANNEL_1, TIM_INPUTCHANNELPOLARITY_RISING);
        }
    }
}

