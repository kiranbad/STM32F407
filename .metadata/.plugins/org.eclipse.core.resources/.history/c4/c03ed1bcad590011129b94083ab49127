/**
  * @brief  Task responsible for polling sensor updates
  */
void SensorTask(void *argument)
{
    LogData_t data;
    while(1)
    {
        data.distance = HCSR04_ReadDistance();
        data.timestamp = xTaskGetTickCount();

        if (data.distance >= 0)
        {
            LatestDistance = data.distance;
            xQueueSend(AlertQueue, &data, 0);
        }

        vTaskDelay(pdMS_TO_TICKS(100));
    }
}

/**
  * @brief  Monitors threshold logic for driving alert hardware
  */
void AlertTask(void *argument)
{
    LogData_t data;
    while(1)
    {
        if(xQueueReceive(AlertQueue, &data, portMAX_DELAY) == pdPASS)
        {
            if(data.distance > ALERT_DISTANCE)
            {
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_SET);
            }
            else
            {
                HAL_GPIO_WritePin(GPIOD, GPIO_PIN_12, GPIO_PIN_RESET);
            }
        }
    }
}

/**
  * @brief  Periodically streams calculated values to UART console
  */
void UARTTask(void *argument)
{
    char msg[100];
    uint32_t tick;

    while(1)
    {
        tick = xTaskGetTickCount();
        sprintf(msg, "Tick=%lu Distance=%.2f cm\r\n", tick, LatestDistance);
        HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

        vTaskDelay(pdMS_TO_TICKS(1000));
    }
}

